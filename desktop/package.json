{
  "name": "glyph-folio-desktop",
  "version": "0.3.2",
  "description": "Quick Typst note-taking with PDF export",
  "author": "Xavier Barton",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "dist": "electron-vite build && electron-builder"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "chokidar": "^3.6.0",
    "dictionary-en": "^4.0.0",
    "dictionary-en-au": "^3.0.0",
    "electron-store": "^10.0.0",
    "node-diff3": "^3.2.0",
    "nspell": "^2.1.5",
    "pdfjs-dist": "^4.4.168",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "31.7.7",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "typescript": "^5.4.5",
    "vite": "^5.3.1"
  },
  "build": {
    "appId": "com.glyph.folio",
    "productName": "Glyph Folio",
    "files": [
      "out/**/*"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": "dmg",
      "icon": "resources/icon.icns"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage",
      "category": "Office"
    }
  }
}
